{
  "name": "hollow-bits",
  "private": true,
  "version": "0.0.0",
  "description": "HOLLOW BITS desktop-first DAW for Windows x64",
  "author": "HOLLOW BITS",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "assets:performer": "python scripts/generate-performer-frames.py",
    "assets:performer:ffmpeg": "node scripts/generate-performer-frames.mjs",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:block3-regression": "vitest run tests/unit/block3CompingReliabilityService.test.ts",
    "test:session-hardening": "vitest run tests/unit/sessionPerformanceService.test.ts",
    "launch:report:baseline": "node scripts/generate-session-launch-report.mjs --out benchmarks/session-launch/latest-report.json",
    "launch:gate": "node scripts/session-launch-gate.mjs",
    "perf:gate": "node scripts/audio-performance-gate.mjs",
    "quality:gates": "npm run typecheck && npm run test:unit && npm run build",
    "build": "tsc && vite build",
    "build:win": "npm run build && electron-builder --win --x64 --publish never",
    "preview": "vite preview",
    "electron": "electron electron/main.cjs --dev",
    "dev:electron": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && npm run electron\""
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.38.0",
    "@spotify/basic-pitch": "^1.0.1",
    "ffmpeg-static": "^5.3.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "electron": "^40.1.0",
    "electron-builder": "^26.7.0",
    "jsdom": "^24.1.3",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.hollowbits.daw",
    "productName": "HOLLOW BITS",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "HOLLOW BITS"
    }
  }
}
