{
  "name": "hollow-bits",
  "private": true,
  "version": "0.0.0",
  "description": "HOLLOW BITS desktop-first DAW for Windows x64",
  "author": "HOLLOW BITS",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "assets:performer": "python scripts/generate-performer-frames.py",
    "assets:performer:ffmpeg": "node scripts/generate-performer-frames.mjs",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:transport-hardening": "vitest run tests/unit/audioEngineTransportAuthority.test.ts tests/unit/transportStateService.test.ts tests/unit/transportClockStore.test.ts",
    "test:block3-regression": "vitest run tests/unit/block3CompingReliabilityService.test.ts",
    "test:block5-regression": "vitest run tests/unit/block5EditingRegression.test.ts tests/unit/takeCompingService.test.ts tests/unit/recordingTakeService.test.ts tests/unit/projectIntegrityService.test.ts tests/unit/projectRecoveryService.test.ts",
    "test:block6-regression": "vitest run tests/unit/block6SessionRegression.test.ts tests/unit/sessionSceneRecordingService.test.ts tests/unit/sessionPerformanceService.test.ts tests/unit/liveCaptureHarnessService.test.ts",
    "test:block7-regression": "vitest run tests/unit/block7MixerRoutingRegression.test.ts tests/unit/mixerAuditService.test.ts tests/unit/automationService.test.ts tests/unit/projectIntegrityService.test.ts",
    "test:session-hardening": "vitest run tests/unit/sessionPerformanceService.test.ts",
    "launch:report:baseline": "node scripts/generate-session-launch-report.mjs --out benchmarks/session-launch/latest-report.json",
    "launch:report:promote": "node scripts/promote-session-launch-report.mjs --in session-launch-report.json --out benchmarks/session-launch/latest-report.json",
    "launch:gate": "node scripts/session-launch-gate.mjs",
    "launch:gate:strict": "node scripts/session-launch-gate.mjs --strict-live-capture",
    "capture:live:48x8": "node scripts/capture-live-48x8.mjs",
    "recording:cycles:gate": "node scripts/recording-cycles-gate.mjs --report benchmarks/recording-reliability/latest-report.json --out benchmarks/recording-reliability/latest-gate.json --cycles 1000",
    "monitoring:gate": "node scripts/monitoring-runtime-gate.mjs --report benchmarks/monitoring-runtime/latest-report.json --out benchmarks/monitoring-runtime/latest-gate.json",
    "block5:gate": "node scripts/block5-editing-gate.mjs --out benchmarks/block5-editing/latest-gate.json --recording-gate benchmarks/recording-reliability/latest-gate.json",
    "block6:gate": "node scripts/block6-session-gate.mjs --out benchmarks/block6-session/latest-gate.json --launch-gate benchmarks/session-launch/latest-gate.json --stress-report benchmarks/stress-48x8/latest-report.json",
    "block7:gate": "node scripts/block7-mixer-gate.mjs --out benchmarks/block7-mixer/latest-gate.json --monitoring-gate benchmarks/monitoring-runtime/latest-gate.json",
    "audio-priority:gate": "node scripts/audio-priority-flapping-gate.mjs --report benchmarks/audio-priority/latest-transitions.json --out benchmarks/audio-priority/latest-gate.json --window-sec 20 --max-transitions 1",
    "transport:gate": "node scripts/transport-command-gate.mjs --out benchmarks/transport/latest-gate.json",
    "stress:48x8:report": "node scripts/generate-48x8-stress-report.mjs --out benchmarks/stress-48x8/latest-report.json",
    "stress:48x8:gate": "node scripts/stress-48x8-gate.mjs --report benchmarks/stress-48x8/latest-report.json",
    "stress:48x8:gate:strict": "node scripts/stress-48x8-gate.mjs --report benchmarks/stress-48x8/latest-report.json --strict-live-capture",
    "release:readiness": "node scripts/release-readiness-report.mjs --out benchmarks/release-readiness/latest-report.json",
    "quality:live-strict": "npm run typecheck && npm run test:unit && npm run build && npm run capture:live:48x8 && npm run transport:gate && npm run launch:gate:strict -- --report benchmarks/session-launch/latest-report.json --out benchmarks/session-launch/latest-gate.json && npm run stress:48x8:gate:strict -- --report benchmarks/stress-48x8/latest-report.json && npm run recording:cycles:gate && npm run monitoring:gate && npm run block5:gate && npm run block6:gate && npm run block7:gate && npm run audio-priority:gate && npm run release:readiness",
    "perf:gate": "node scripts/audio-performance-gate.mjs",
    "quality:gates": "npm run typecheck && npm run test:unit && npm run build",
    "build": "tsc && vite build",
    "build:win": "npm run build && electron-builder --win --x64 --publish never",
    "preview": "vite preview",
    "electron": "electron electron/main.cjs --dev",
    "dev:electron": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && npm run electron\""
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.38.0",
    "@spotify/basic-pitch": "^1.0.1",
    "@supabase/supabase-js": "^2.105.1",
    "ffmpeg-static": "^5.3.0",
    "jszip": "^3.10.1",
    "localforage": "^1.10.0",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "electron": "^40.1.0",
    "electron-builder": "^26.7.0",
    "jsdom": "^24.1.3",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.hollowbits.daw",
    "productName": "HOLLOW BITS",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "HOLLOW BITS"
    }
  }
}
